# Generated by packages/shared/scripts/generate-env-example.ts from env-schema and ENV_VAR_DOCS.
# Do not edit by hand; run: pnpm generate:env-example

# Database (omit for embedded Postgres)

# PostgreSQL connection string; omit for embedded Postgres Required when postgres.
# DATABASE_URL=


# Server

# Node environment (production enables strict env allowlist) (default: development)
NODE_ENV=development

# Server host binding (default: 127.0.0.1)
HOST=127.0.0.1

# Server port (default: 3100)
PORT=3100

# Serve the board UI from the API server (default: true)
SERVE_UI=true


# Hive paths

# Base directory for all Hive data (default: ~/.hive)
HIVE_HOME=~/.hive

# Instance identifier (for multiple local instances) (default: default)
HIVE_INSTANCE_ID=default

# Path to config file (derived from HIVE_HOME/instance if unset)
# HIVE_CONFIG=

# Path to context file
# HIVE_CONTEXT=


# Deployment and auth

# Public base URL for the control plane
# HIVE_PUBLIC_URL=

# Auth public base URL
# HIVE_AUTH_PUBLIC_BASE_URL=

# Deployment mode (default: local_trusted)
HIVE_DEPLOYMENT_MODE=local_trusted

# Deployment exposure when authenticated (default: private)
HIVE_DEPLOYMENT_EXPOSURE=private

# Auth base URL mode (default: auto)
HIVE_AUTH_BASE_URL_MODE=auto

# Comma-separated hostnames for private access
# HIVE_ALLOWED_HOSTNAMES=

# Enable Vite dev middleware for UI (default: false)
HIVE_UI_DEV_MIDDLEWARE=false

# Disable new sign-ups (default: false)
HIVE_AUTH_DISABLE_SIGN_UP=false


# Auth (authenticated mode)

# Agent JWT signing secret Required when authenticated.
# HIVE_AGENT_JWT_SECRET=

# Better Auth session secret Required when authenticated.
# BETTER_AUTH_SECRET=

# Auth public base URL (legacy)
# BETTER_AUTH_URL=

# Auth public base URL (legacy)
# BETTER_AUTH_BASE_URL=

# Comma-separated trusted origins for auth
# BETTER_AUTH_TRUSTED_ORIGINS=


# Secrets

# 32-byte encryption key (base64/hex/raw)
# HIVE_SECRETS_MASTER_KEY=

# Path to secrets master key file
# HIVE_SECRETS_MASTER_KEY_FILE=

# Secrets provider (default: local_encrypted)
HIVE_SECRETS_PROVIDER=local_encrypted

# Require secret refs for sensitive env vars (default: false)
HIVE_SECRETS_STRICT_MODE=false


# Storage

# Storage provider (default: local_disk)
HIVE_STORAGE_PROVIDER=local_disk

# Base dir for local disk storage
# HIVE_STORAGE_LOCAL_DIR=

# S3 bucket name (default: hive)
HIVE_STORAGE_S3_BUCKET=hive

# S3 region (default: us-east-1)
HIVE_STORAGE_S3_REGION=us-east-1

# Custom S3 endpoint
# HIVE_STORAGE_S3_ENDPOINT=

# S3 key prefix (default: )
# HIVE_STORAGE_S3_PREFIX=

# Use path-style S3 URLs (default: false)
HIVE_STORAGE_S3_FORCE_PATH_STYLE=false


# DB backup

# Enable DB backups (default: true)
HIVE_DB_BACKUP_ENABLED=true

# Backup interval in minutes (default: 60)
HIVE_DB_BACKUP_INTERVAL_MINUTES=60

# Retention days for backups (default: 30)
HIVE_DB_BACKUP_RETENTION_DAYS=30

# Backup directory (derived if unset)
# HIVE_DB_BACKUP_DIR=


# CORS and rate limiting

# Comma-separated allowed CORS origins; empty means none
# HIVE_CORS_ORIGINS=

# Rate limit window in ms (default: 900000)
HIVE_RATE_LIMIT_WINDOW_MS=900000

# Max general /api requests per window per IP (sensitive routes use a stricter cap) (default: 4000)
HIVE_RATE_LIMIT_MAX=4000


# Heartbeat

# Enable heartbeat scheduler (default: true)
HEARTBEAT_SCHEDULER_ENABLED=true

# Heartbeat interval in ms (default: 30000)
HEARTBEAT_SCHEDULER_INTERVAL_MS=30000


# Attachments

# Max attachment size in bytes (default: 10485760)
HIVE_ATTACHMENT_MAX_BYTES=10485760

# Comma-separated MIME patterns for attachments
# HIVE_ALLOWED_ATTACHMENT_TYPES=


# Optional

# Allow company deletion (mode-dependent if unset)
# HIVE_ENABLE_COMPANY_DELETION=

# Host the server listens on
# HIVE_LISTEN_HOST=

# Port the server listens on
# HIVE_LISTEN_PORT=

# API base URL (for agents and CLI)
# HIVE_API_URL=

# Open browser when server starts (default: false)
HIVE_OPEN_ON_LISTEN=false

# Base path for run logs
# RUN_LOG_BASE_PATH=

# Comma-separated adapter types for join
# HIVE_JOIN_ALLOWED_ADAPTER_TYPES=

# Comma-separated URLs/hosts allowed for worker WebSocket link
# HIVE_MANAGED_WORKER_URL_ALLOWLIST=

# GitHub repo for update check
# HIVE_RELEASES_REPO=

# Set to 1 to disable update check (default: false)
HIVE_UPDATE_CHECK_DISABLED=false

# HTTPS URL of hive-worker manifest JSON; if set, worker download API uses manifest-only (no GitHub API)
# HIVE_WORKER_MANIFEST_URL=

# GitHub owner/repo for worker binaries; default follows HIVE_RELEASES_REPO when unset
# HIVE_WORKER_RELEASES_REPO=

# GitHub release tag for worker assets (e.g. v0.2.7); default v + control-plane APP_VERSION
# HIVE_WORKER_RELEASE_TAG=

# GitHub mode only: HTTPS prefix (no trailing slash) mirroring release filenames; download URLs point here
# HIVE_WORKER_ARTIFACT_BASE_URL=

# Optional PAT for GitHub API (worker downloads / rate limits / private repo)
# HIVE_GITHUB_TOKEN=

# Agent JWT TTL in seconds
# HIVE_AGENT_JWT_TTL_SECONDS=

# Agent JWT issuer claim
# HIVE_AGENT_JWT_ISSUER=

# Agent JWT audience claim
# HIVE_AGENT_JWT_AUDIENCE=

# Server host (E2E/test)
# HIVE_SERVER_HOST=

# Server port (E2E/test)
# HIVE_SERVER_PORT=

# E2E test port
# HIVE_E2E_PORT=

# Skip LLM in E2E
# HIVE_E2E_SKIP_LLM=

# Prompt before applying migrations
# HIVE_MIGRATION_PROMPT=

# Auto-apply migrations
# HIVE_MIGRATION_AUTO_APPLY=

# Running inside a worktree
# HIVE_IN_WORKTREE=

# Codex adapter home dir
# CODEX_HOME=

# Claude adapter home dir
# CLAUDE_HOME=

# Server log directory
# HIVE_LOG_DIR=


# Other

# When true, the local_trusted synthetic board user (`local-board`) is evaluated through normal company permission grants instead of bypassing RBAC. Use in CI or integration tests only; keep false/unset for normal local dev ergonomics. (default: false)
HIVE_RBAC_ENFORCE_FOR_LOCAL_BOARD=false

# Vault/OpenBao base URL (for vault provider)
# HIVE_VAULT_ADDR=

# Vault/OpenBao token (for vault provider)
# HIVE_VAULT_TOKEN=

# Vault namespace (optional)
# HIVE_VAULT_NAMESPACE=

# Vault/OpenBao KV v2 mount path (default: hive)
HIVE_VAULT_KV_MOUNT=hive

# Bifrost HTTP base URL (e.g. http://bifrost:8080) for governance virtual-key provisioning from the board
# HIVE_BIFROST_ADMIN_BASE_URL=

# Bearer token for Bifrost /api/governance/* when provisioning sk-bf-* keys from the control plane
# HIVE_BIFROST_ADMIN_TOKEN=

# When true, managed-worker runs record run_placements and send placementId/expectedWorkerInstanceId to the drone (ADR 002); requires compatible hive-worker (default: false)
HIVE_PLACEMENT_V1_ENABLED=false

# When true, agents with worker_placement_mode=automatic may get a worker_instance_agents row picked by the control plane (ADR 005); opt-in server gate (default: false)
HIVE_AUTO_PLACEMENT_ENABLED=false

# When false, disable automatic creation of managed_worker agents from company worker-identity desired-state slots (default: enabled when unset). (default: true)
HIVE_WORKER_IDENTITY_AUTOMATION_ENABLED=true

# Background interval to reconcile worker identity slots + automatic placement for companies with active slots (ms); 0 disables periodic runs (provision-hello trigger still runs). Default 300000. (default: 300000)
HIVE_WORKER_AUTOMATION_RECONCILE_INTERVAL_MS=300000

# When true, requesting drain on a worker instance (PATCH) moves identities with automatic assignment to another eligible non-draining drone (ADR 005 Phase C); default off (default: false)
HIVE_DRAIN_AUTO_EVACUATE_ENABLED=false

# When true (default), marking a worker instance draining cancels queued/running heartbeat runs still placed on that instance and fails placement rows (cancel+requeue policy). Set false to only block new runs. (default: true)
HIVE_DRAIN_CANCEL_IN_FLIGHT_PLACEMENTS_ENABLED=true

# When true, enables POST /api/companies/:companyId/integrations/github/webhook (raw body) for merge-driven execution workspace teardown; requires HIVE_VCS_GITHUB_WEBHOOK_SECRET (default: false)
HIVE_VCS_GITHUB_WEBHOOK_ENABLED=false

# GitHub webhook signing secret (HMAC SHA-256) shared with the GitHub App / webhook configuration
# HIVE_VCS_GITHUB_WEBHOOK_SECRET=

# Optional comma-separated owner/repo list; pull_request events for other repositories are ignored (empty = allow all)
# HIVE_VCS_GITHUB_ALLOWED_REPOS=

# URL for cross-replica managed-worker WebSocket delivery (Redis protocol: PUBLISH/SUBSCRIBE via ioredis). Use managed Redis, Dragonfly, Valkey, or other RESP-compatible service; omit for single-replica; required for HA with multiple API replicas (ADR 003).
# HIVE_WORKER_DELIVERY_BUS_URL=

# When true, expose GET /api/metrics for Prometheus (protect with network policy; not authenticated by default) (default: false)
HIVE_METRICS_ENABLED=false

# When true, instance admins may run DB migrations from the board UI (POST /api/instance/migrations/apply). If unset, defaults to on in local_trusted and off in authenticated mode.
# HIVE_UI_MIGRATIONS_ENABLED=

# Optional inline JSON object for worker runtime provisioning manifest (adapterKey -> {url,sha256}) served by the control plane
# HIVE_WORKER_PROVISION_MANIFEST_JSON=

# Optional path to worker provisioning manifest JSON file (used when inline JSON is unset)
# HIVE_WORKER_PROVISION_MANIFEST_FILE=

# Optional PEM file path for Ed25519 private key used to sign GET provision manifest JSON responses (X-Hive-Manifest-Signature header)
# HIVE_WORKER_PROVISION_MANIFEST_SIGNING_KEY_FILE=

# Optional inline PEM or base64-encoded PEM for Ed25519 manifest signing (prefer _SIGNING_KEY_FILE in production)
# HIVE_WORKER_PROVISION_MANIFEST_SIGNING_KEY=

# HS256 secret for drone worker-instance JWT (`/api/worker-api/*`, WebSocket worker_api_token); omit to disable
# HIVE_WORKER_JWT_SECRET=

# Shared symmetric secret: worker verifies HMAC on WebSocket worker_container_policy; control plane uses the same value to sign when HIVE_WORKER_CONTAINER_POLICY_ALLOWLIST_CSV is set. Must match the worker's HIVE_WORKER_POLICY_SECRET.
# HIVE_WORKER_POLICY_SECRET=

# Comma-separated container image registry prefixes pushed to drones as signed worker_container_policy after link hello (requires HIVE_WORKER_POLICY_SECRET on control plane and worker). Example: ghcr.io/my-org/,registry.example.com/proj/
# HIVE_WORKER_CONTAINER_POLICY_ALLOWLIST_CSV=

# Policy document version string included in the HMAC payload (default 1) (default: 1)
HIVE_WORKER_CONTAINER_POLICY_VERSION=1

# Optional ISO-8601 expiry (e.g. 2099-12-31T23:59:59Z) included in signature; empty string if omitted
# HIVE_WORKER_CONTAINER_POLICY_EXPIRES_AT=

# When true, heartbeat runs that use a control-plane-local git worktree (isolated execution workspace) fail fast instead of sending paths a remote drone cannot access. See docs/deploy/execution-workspace-remote-workers.md (default: false)
HIVE_WORKSPACE_REMOTE_EXEC_GUARD=false

# Worker JWT TTL in seconds (default 86400)
# HIVE_WORKER_JWT_TTL_SECONDS=

# Worker JWT issuer claim
# HIVE_WORKER_JWT_ISSUER=

# Worker JWT audience claim
# HIVE_WORKER_JWT_AUDIENCE=

# When set in local_trusted, enables POST /api/e2e/mcp-smoke/materialize with header X-Hive-E2E-MCP-Secret (Playwright MCP smoke only; do not set in production)
# HIVE_E2E_MCP_MATERIALIZE_SECRET=
