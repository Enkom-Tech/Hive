{
  "name": "hive",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-runner.mjs watch",
    "dev:watch": "node scripts/dev-runner.mjs watch",
    "dev:once": "node scripts/dev-runner.mjs dev",
    "dev:server": "pnpm --filter @hive/server dev",
    "dev:ui": "pnpm --filter @hive/ui dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm exec vitest",
    "test:run": "pnpm exec vitest run",
    "test:coverage": "pnpm exec vitest run --coverage",
    "test:coverage:server": "pnpm exec vitest run --config server/vitest.config.ts --coverage",
    "db:generate": "pnpm --filter @hive/db generate",
    "db:migrate": "pnpm --filter @hive/db migrate",
    "secrets:migrate-inline-env": "tsx scripts/migrate-inline-env-secrets.ts",
    "generate:env-example": "pnpm --filter @hive/shared generate:env-example",
    "db:backup": "./scripts/backup-db.sh",
    "hive": "node node_modules/tsx/dist/cli.mjs cli/src/index.ts",
    "build:npm": "./scripts/build-npm.sh",
    "release:start": "./scripts/release-start.sh",
    "release": "./scripts/release.sh",
    "release:preflight": "./scripts/release-preflight.sh",
    "release:github": "./scripts/create-github-release.sh",
    "release:rollback": "./scripts/rollback-latest.sh",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "check:tokens": "node scripts/check-forbidden-tokens.mjs",
    "check:legacy-drone-api": "node scripts/check-legacy-drone-api.mjs",
    "doc:export-avatar-pngs": "node scripts/export-avatar-pngs.mjs",
    "docs:dev": "cd docs && npx mintlify dev",
    "test:e2e": "pnpm exec playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:headed": "pnpm exec playwright test --config tests/e2e/playwright.config.ts --headed",
    "test:e2e:onboarding": "pnpm exec playwright test tests/e2e/onboarding.spec.ts --config tests/e2e/playwright.config.ts",
    "test:e2e:smoke-mcp": "pnpm exec playwright test tests/e2e/z-mcp-worker-api-smoke.spec.ts --config tests/e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.4",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "auditConfig": {
      "ignoreGhsas": ["GHSA-6cpc-mj5c-m9rq"]
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "path-to-regexp": "^8.4.0",
      "lodash-es": "^4.18.0",
      "picomatch": "^2.3.2",
      "brace-expansion": "^2.0.3",
      "@tootallnate/once": "^3.0.1",
      "esbuild": "^0.28.0",
      "defu": "^6.1.5"
    }
  }
}
