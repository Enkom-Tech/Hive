{
  "name": "@hive/server",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "ui-dist",
    "skills"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "cross-env HIVE_MIGRATION_PROMPT=never node --watch --import tsx --watch-path=./src --watch-path=../packages/db/src --watch-path=../packages/shared/src --watch-path=../packages/adapter-utils/src ./src/index.ts",
    "prepare:ui-dist": "bash ../scripts/prepare-server-ui-dist.sh",
    "build": "tsc",
    "prepack": "pnpm run prepare:ui-dist",
    "postpack": "rm -rf ui-dist",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/client-secrets-manager": "^3.1033.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/middie": "^9.3.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@google-cloud/secret-manager": "^6.1.1",
    "@hive/adapter-utils": "workspace:*",
    "@hive/db": "workspace:*",
    "@hive/plugin-sdk": "workspace:*",
    "@hive/shared": "workspace:*",
    "better-auth": "^1.6.5",
    "detect-port": "^2.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "embedded-postgres": "18.3.0-beta.17",
    "fastify": "^5.8.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "open": "^11.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "postgres": "^3.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  }
}
