{
  "name": "@hive/server",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "ui-dist",
    "skills"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "cross-env HIVE_MIGRATION_PROMPT=never node --watch --import tsx --watch-path=./src --watch-path=../packages/db/src --watch-path=../packages/shared/src --watch-path=../packages/adapter-utils/src ./src/index.ts",
    "prepare:ui-dist": "bash ../scripts/prepare-server-ui-dist.sh",
    "build": "tsc",
    "prepack": "pnpm run prepare:ui-dist",
    "postpack": "rm -rf ui-dist",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@aws-sdk/client-secrets-manager": "^3.1013.0",
    "@google-cloud/secret-manager": "^6.1.1",
    "@hive/adapter-utils": "workspace:*",
    "@hive/db": "workspace:*",
    "@hive/shared": "workspace:*",
    "better-auth": "^1.5.4",
    "cors": "^2.8.5",
    "detect-port": "^2.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "embedded-postgres": "18.3.0-beta.16",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.8.2",
    "prom-client": "^15.1.3",
    "multer": "^2.1.1",
    "open": "^11.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "postgres": "^3.4.8",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
