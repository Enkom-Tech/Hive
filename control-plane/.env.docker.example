# Copy to .env in this directory and fill in values, then:
#   docker compose --env-file .env -f docker-compose.external-db.yml up --build
# (Quickstart compose only needs BETTER_AUTH_SECRET; use the same pattern with docker-compose.quickstart.yml.)

# Required for docker-compose.external-db.yml — URL must work from *inside* the container.
# Example when Postgres listens on the Docker host (Desktop / Linux with host-gateway):
# DATABASE_URL=postgres://hive:hive@host.docker.internal:5432/hive
DATABASE_URL=

# Required for authenticated Docker modes (quickstart, external-db, docker-compose.yml).
BETTER_AUTH_SECRET=

# Browser URL for auth callbacks and hostname allowlist (must match how you open the app).
# If you change HIVE_PORT, set this to the same host port (e.g. http://localhost:3200).
HIVE_PUBLIC_URL=http://localhost:3100

# Optional
# HIVE_PORT=3100
# HIVE_DATA_DIR=./data/docker-hive
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
