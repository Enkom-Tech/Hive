# Hive infra Makefile. Run from infra/ (or via root: make -C infra <target>).
# Operator, worker, and envtest require Linux (WSL2 on Windows). Run from WSL2.

SHELL := /bin/bash
ROOT := $(dir $(abspath $(lastword $(MAKEFILE_LIST))))

GOBIN := $(shell go env GOBIN 2>/dev/null)
ifeq ($(GOBIN),)
  GOBIN := $(shell go env GOPATH)/bin
endif

# Detect Linux (WSL2 reports as Linux). Fail fast on Windows native.
UNAME_S := $(shell uname -s 2>/dev/null || echo Unknown)
ifeq ($(UNAME_S),Linux)
  WSL_OR_LINUX := 1
else ifeq ($(UNAME_S),Darwin)
  WSL_OR_LINUX := 1
else
  WSL_OR_LINUX :=
endif

.PHONY: check-env
check-env:
ifndef WSL_OR_LINUX
	@echo "ERROR: Hive operator and tests require Linux or macOS (e.g. WSL2)."
	@echo "  On Windows: open WSL2 (wsl) and run 'make' from the repo root inside WSL2."
	@echo "  Uname reported: $(UNAME_S)"
	@exit 1
endif
	@echo "Environment OK ($(UNAME_S))"

.PHONY: ci
ci: check-env lint test build scan

.PHONY: lint
lint: check-env
	$(MAKE) -C operator lint
	$(MAKE) -C worker lint
	$(MAKE) lint-manifests

.PHONY: lint-manifests
lint-manifests: check-env
	@test -x $(GOBIN)/kubeconform || (echo "Install kubeconform: go install github.com/yannh/kubeconform/cmd/kubeconform@latest"; exit 1)
	$(GOBIN)/kubeconform -strict -skip Certificate -skip CertificateSigningRequest -skip Ingress $$(find manifests -name '*.yaml' 2>/dev/null) 2>/dev/null || true
	@test -x $(GOBIN)/kube-linter || (echo "Install kube-linter: https://github.com/stackrox/kube-linter"; exit 0)
	@test -x $(GOBIN)/kube-linter && $(GOBIN)/kube-linter lint manifests/ 2>/dev/null || true

# test: unit tests only. Controller integration tests (envtest) run via: make -C operator test-integration
.PHONY: test
test: check-env test-unit

.PHONY: test-unit
test-unit: check-env
	$(MAKE) -C operator test-unit
	$(MAKE) -C worker test-unit

.PHONY: test-integration
test-integration: check-env
	$(MAKE) -C operator test-integration

.PHONY: build
build: check-env
	$(MAKE) -C operator docker-build
	$(MAKE) -C worker docker-build

.PHONY: scan
scan: check-env scan-images
	$(MAKE) -C operator gosec
	$(MAKE) -C operator govulncheck
	$(MAKE) -C worker gosec
	$(MAKE) -C worker govulncheck

.PHONY: scan-images
scan-images: check-env
	@command -v trivy >/dev/null 2>&1 || (echo "Install trivy for image scanning"; exit 0)
	$(MAKE) -C operator docker-build 2>/dev/null || true
	$(MAKE) -C worker docker-build 2>/dev/null || true
	trivy image --exit-code 0 --severity CRITICAL,HIGH hive-operator:latest hive-worker:latest 2>/dev/null || true

# Build all images required for e2e (operator, worker, mock-controlplane). make e2e depends on this.
.PHONY: e2e-build
e2e-build: check-env
	$(MAKE) -C operator docker-build
	$(MAKE) -C worker docker-build
	docker build -t mock-controlplane:latest e2e/testdata/mock-controlplane

# Copy generated CRDs from operator into manifests/crds for apply/deploy.
# Source of truth: operator/config/crd/bases (generated by controller-gen).
.PHONY: crds
crds: check-env
	@mkdir -p manifests/crds
	cp operator/config/crd/bases/*.yaml manifests/crds/

.PHONY: e2e
e2e: check-env crds e2e-build
	E2E_KIND=1 $(MAKE) -C e2e test

# Registry-based e2e: cluster uses local registry for worker image (CI-friendly).
.PHONY: e2e-with-registry
e2e-with-registry: check-env crds e2e-build
	$(MAKE) -C e2e test-with-registry

.PHONY: clean
clean:
	$(MAKE) -C operator clean 2>/dev/null || true
	$(MAKE) -C worker clean 2>/dev/null || true
	$(MAKE) -C e2e clean 2>/dev/null || true
