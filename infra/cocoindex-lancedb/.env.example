# Copy this file to .env and fill in real values for local development.
# NEVER commit .env to source control.
# In Kubernetes, inject these values via secretKeyRef from K8s Secrets.

# DragonflyDB password (must match the value used by the dragonfly service)
DRAGONFLY_PASSWORD=change-me-before-use

# API token for CocoIndex HTTP API (all endpoints except /health require this)
COCOINDEX_API_TOKEN=change-me-before-use

# Optional tuning (defaults are safe for single-GPU llama.cpp)
# COCOINDEX_EMBEDDING_MAX_CONCURRENT_BATCHES=1
# COCOINDEX_MAX_CONCURRENT_FILE_TASKS=8
# COCOINDEX_RATE_LIMIT_INDEX=10/minute
# COCOINDEX_RATE_LIMIT_SEARCH=60/minute
