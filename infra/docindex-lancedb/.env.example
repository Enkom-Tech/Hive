# Copy to .env for docker compose. Do not commit .env.

# Bearer token for DocIndex HTTP API (all routes except /health)
DOCINDEX_API_TOKEN=change-me-before-use

# Queue password for the internal Redis/DragonflyDB job queue.
# Use a strong random value: openssl rand -hex 32
DOCINDEX_QUEUE_PASSWORD=change-me-before-use

# HMAC key for signing job messages between API and worker.
# Use a strong random value: openssl rand -hex 32
DOCINDEX_JOB_SIGNING_KEY=change-me-before-use

# Optional: sample successful auth audit logs (0 = failures only; 1 = always)
# DOCINDEX_AUTH_SUCCESS_LOG_SAMPLE_RATE=0
