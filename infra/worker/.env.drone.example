# Control plane HTTP(S) base (worker derives WebSocket URL for /api/workers/link)
HIVE_CONTROL_PLANE_URL=https://your-board.example.com

# One of: drone-first bootstrap (consumed on first successful provision hello)
HIVE_DRONE_PROVISION_TOKEN=hive_dpv_REPLACE_ME
# Or agent-scoped link (enrollment secret or long-lived API key)
# HIVE_AGENT_ID=
# HIVE_AGENT_KEY=

# Persist instance id + link token across restarts
HIVE_WORKER_STATE_DIR=/state

# Workspace root (must match health check path in image; override if you change Dockerfile)
HIVE_WORKSPACE=/workspace/repo

# Published adapter commands (see infra/worker internal adapter registry)
# HIVE_ADAPTER_DEFAULT_CMD=
# HIVE_ADAPTER_claude_CMD=claude
# HIVE_ADAPTER_codex_CMD=codex

# Lazy-download adapter binaries (HTTPS only) or use board manifest:
# HIVE_PROVISION_MANIFEST_URL=https://your-board.example.com/api/companies/COMPANY_UUID/worker-runtime/manifest
# Optional explicit Bearer for manifest GET (else worker uses link credentials: dpv / agent key / link-token):
# HIVE_PROVISION_MANIFEST_BEARER=
# Opt-in startup hooks (apt/npm/docker) from manifest — not on default distroless image:
# HIVE_PROVISION_MANIFEST_HOOKS=1
# Matches docker-compose.drone.yml volume mount (override only if you change the mount path)
HIVE_PROVISION_CACHE_DIR=/cache

# Publish host port -> container 8080
HIVE_WORKER_PUBLISH_PORT=8080

# Optional: multi-link JSON for several identities on one process
# HIVE_WORKER_LINKS_JSON=
